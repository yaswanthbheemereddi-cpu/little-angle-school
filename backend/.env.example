PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/littleangels

JWT_SECRET=your_jwt_secret_key_here

# ─── Email Configuration ───────────────────────────────────────────────────────
# Gmail account used to SEND emails from the website
# Important: Use an App Password, NOT your normal Gmail password.
# How to get an App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Then go to "App passwords" → create one for "Mail"
EMAIL_USER=yourschool@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# The school's email address that will RECEIVE admission & contact notifications
SCHOOL_EMAIL=principal@littleangelsschool.in

# Email service (default: gmail — supported services: gmail, yahoo, hotmail)
EMAIL_SERVICE=gmail
